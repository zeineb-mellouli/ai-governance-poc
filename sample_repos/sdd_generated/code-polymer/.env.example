# Polymer Pricing ETL Pipeline — environment variable template
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control (it is listed in .gitignore).
# See contracts/pipeline-contracts.md §6 for the full contract.

# ── Azure SQL Server (Constitution I: credentials from env vars only) ──────
# Full hostname of the Azure SQL Server instance
SQL_SERVER=myserver.database.windows.net

# Target database name
SQL_DATABASE=PolymerReporting

# SQL login username
SQL_USERNAME=svc_pipeline

# SQL login password  ← KEEP THIS SECRET
SQL_PASSWORD=<replace-with-secret>

# ── Pipeline data directories ──────────────────────────────────────────────
# Absolute or relative path to the landing zone (source CSVs dropped here)
LANDING_DIR=data/landing

# Absolute or relative path to the bronze layer root
BRONZE_DIR=data/bronze

# Absolute or relative path to the silver layer root
SILVER_DIR=data/silver

# Absolute or relative path to the gold layer root
GOLD_DIR=data/gold

# ── Logging ───────────────────────────────────────────────────────────────
# Absolute or relative path for pipeline log files (Constitution IV)
LOG_DIR=logs
